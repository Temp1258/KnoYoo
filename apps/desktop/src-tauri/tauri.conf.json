{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KnoYoo",
  "version": "0.2.0",
  "identifier": "com.knoyoo.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "desktop",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "targets": ["msi"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "wix": { "language": "zh-CN" }
    }
  }
}
