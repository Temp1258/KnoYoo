# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# SQLite database (user data, should not be version-controlled)
notes.db
notes.db-journal
notes.db-wal

# Sidecar binaries — fetched by scripts/fetch-sidecars.{sh,ps1} before build.
# Too large to commit (yt-dlp ~30MB, ffmpeg ~80MB per platform).
binaries/*
!binaries/.gitkeep
